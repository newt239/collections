{
  "name": "next-template",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "next build",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "codecheck": "pnpm run typecheck && pnpm run lint && pnpm run format && pnpm run knip",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply DB --local",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "dev": "next dev --turbopack",
    "format": "oxfmt --check",
    "format:fix": "oxfmt",
    "knip": "knip",
    "lint": "oxlint --type-aware",
    "lint:fix": "oxlint --fix",
    "preinstall": "npx only-allow pnpm",
    "prepare": "panda codegen && wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "start": "next start",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:watch": "vitest",
    "typecheck": "panda codegen && npx tsc --noEmit"
  },
  "dependencies": {
    "@ark-ui/react": "5.37.2",
    "@opennextjs/cloudflare": "1.19.11",
    "better-auth": "1.6.20",
    "drizzle-orm": "0.45.2",
    "lucide-react": "1.21.0",
    "nanoid": "5.1.15",
    "next": "16.2.9",
    "next-themes": "0.4.6",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "server-only": "0.0.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@pandacss/dev": "1.11.3",
    "@park-ui/panda-preset": "0.43.1",
    "@playwright/test": "1.61.0",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "26.0.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "drizzle-kit": "0.31.10",
    "jsdom": "29.1.1",
    "knip": "6.17.1",
    "lefthook": "2.1.9",
    "oxfmt": "0.55.0",
    "oxlint": "1.70.0",
    "oxlint-tsgolint": "0.23.0",
    "postcss": "8.5.15",
    "typescript": "6.0.3",
    "vite": "8.0.16",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "4.1.9",
    "wrangler": "4.103.0"
  },
  "packageManager": "pnpm@11.0.1"
}
